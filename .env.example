# Инструменты для сканирования (через запятую)
SCAN_SYMBOLS=EURUSD=X,GBPUSD=X,USDJPY=X,AUDUSD=X,USDCAD=X,EURGBP=X,USDCHF=X,EURJPY=X,GBPJPY=X,GC=F,SI=F,CL=F,BZ=F,NG=F,HG=F,PL=F,ES=F,NQ=F,BTC-USD,ETH-USD,ZN=F

# Интервал свечей и период истории
YFINANCE_INTERVAL=5m
YFINANCE_PERIOD=1mo

# Как часто сканировать (секунды)
POLL_INTERVAL_SEC=300

# Через сколько минут проверять точность (через запятую)
VERIFY_HORIZONS=15,30,60

LOG_LEVEL=INFO

# FxPro API (опционально, по умолчанию выключено — используется yfinance)
FXPRO_ENABLED=false
FXPRO_CLIENT_ID=
FXPRO_CLIENT_SECRET=
FXPRO_ACCOUNT_ID=
FXPRO_API_URL=https://connect.fxpro.com/api/v1

# Гипотетический счёт для расчёта P&L
ACCOUNT_BALANCE=250.0
LOT_SIZE=0.01

# Whale-трекер
WHALE_COT_ENABLED=true
WHALE_SENTIMENT_ENABLED=false
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# Стратегия Leaders (copy-trading за китами)
LEADERS_ENABLED=true
LEADERS_MAX_POSITIONS=20
LEADERS_CAPITAL_PCT=0.67
LEADERS_SL_ATR=2.0
LEADERS_TRAIL_ATR=0.7

# Стратегия Outsiders (extreme setups)
OUTSIDERS_ENABLED=true
OUTSIDERS_MAX_POSITIONS=50
OUTSIDERS_CAPITAL_PCT=0.33
OUTSIDERS_MODE=confirmed

# Shadow analytics
SHADOW_ENABLED=true

# Скальпинг-стратегии
SCALPING_VWAP_ENABLED=true
SCALPING_STATARB_ENABLED=true
SCALPING_ORB_ENABLED=true
SCALPING_MAX_POSITIONS=50

# cTrader Open API (автоторговля)
CTRADER_TRADING_ENABLED=false
CTRADER_HOST_TYPE=demo
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_REDIRECT_URI=https://openapi.ctrader.com/apps/token

# Kill Switch (защита от потерь)
KILLSWITCH_MAX_DAILY_LOSS=50.0
KILLSWITCH_MAX_DRAWDOWN_PCT=20.0
KILLSWITCH_MAX_POSITIONS=10
KILLSWITCH_MAX_LOSS_PER_TRADE=25.0

# ═══════════════════════════════════════════════════════════════
# BYBIT CRYPTO BOT (отдельный бот, отдельный контейнер)
# ═══════════════════════════════════════════════════════════════
#
# Единственный источник правды для дефолтов — settings.py.
# Здесь задаются только переменные, которые ОТЛИЧАЮТСЯ от дефолтов,
# плюс секреты (API_KEY, API_SECRET).
# Если переменная не задана — Pydantic берёт default из кода.

# Bybit API (создать на bybit.com → API Management → Demo Trading)
BYBIT_BOT_API_KEY=
BYBIT_BOT_API_SECRET=
BYBIT_BOT_DEMO=true
BYBIT_BOT_TRADING_ENABLED=true

# Список символов: по умолчанию берётся из DEFAULT_SYMBOLS в settings.py (42 шт).
# Раскомментируй для override:
# BYBIT_BOT_SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Управление капиталом (defaults: balance=500, leverage=5, pct=0.05)
# Раскомментируй для override:
# BYBIT_BOT_ACCOUNT_BALANCE=500
# BYBIT_BOT_LEVERAGE=5

# Kill Switch (defaults: daily_loss=37.50, drawdown=25%, positions=5)
# Раскомментируй для override:
# BYBIT_BOT_KS_MAX_DAILY_LOSS=37.50
# BYBIT_BOT_KS_MAX_DRAWDOWN_PCT=25.0
# BYBIT_BOT_KS_MAX_POSITIONS=5

BYBIT_BOT_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# AI-TRADER (DeepSeek-V4, отдельный бот, отдельный контейнер)
# ═══════════════════════════════════════════════════════════════
#
# Single source of truth (с 2026-05-08, см. BUILDLOG_AI_TRADER.md):
#   1. `.env` (этот файл / на VPS) — production-overrides + секреты.
#   2. `src/ai_trader/config/settings.py` Field(default=...) —
#      кодовые defaults (fallback для pytest, локалки и любого
#      случая когда переменной нет в .env).
#   3. `docker-compose.yml` НЕ хранит `${...:-default}` для AI_TRADER_*
#      параметров — раньше это создавало 3-слойную параметризацию
#      (settings/compose/.env), что путало и приводило к рассинхрону.
#
# Чтобы поменять любой параметр на проде — задавай его в `.env` на VPS.
# Если параметра в .env нет — применяется default из `settings.py`.
# Compose только проксирует env_file: .env в окружение контейнера.

# DeepSeek API (ключ из https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Bybit API — отдельные ключи от bybit-bot для аудита.
AI_TRADER_BYBIT_API_KEY=
AI_TRADER_BYBIT_API_SECRET=
AI_TRADER_BYBIT_DEMO=true
AI_TRADER_TRADING_ENABLED=false

# Список пар. ВАЖНО: НЕ должен пересекаться с BYBIT_BOT_SCAN_SYMBOLS
# (SOL/ADA/LINK/SUI/TON/WIF/TIA/DOT) — иначе оба бота будут вести одну
# пару, и непонятно чьи открытые позиции. Проверяй diff `.env` при
# любых изменениях.
# Default из settings.py (DEFAULT_AI_SYMBOLS, 10 пар) применяется только
# если переменная не задана здесь.
AI_TRADER_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,AVAXUSDT,LTCUSDT,ATOMUSDT,WLDUSDT,TAOUSDT

# Двойной таймер (v0.10, 2026-05-10): full-cycle делает полный анализ
# (macro + news + indicators), review-cycle между full только следит за
# уже открытыми позициями (close/hold, без open) — даёт LLM в 3х больше
# точек реакции на adverse evidence. 0 = review отключён.
# AI_TRADER_POLL_INTERVAL_SEC=900     # full-cycle (15 мин)
# AI_TRADER_REVIEW_INTERVAL_SEC=300   # review-cycle (5 мин)

# Telegram (общий с другими ботами; пусто = TG-модуль молчит)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
