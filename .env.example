# Инструменты для сканирования (через запятую)
SCAN_SYMBOLS=EURUSD=X,GBPUSD=X,USDJPY=X,AUDUSD=X,USDCAD=X,EURGBP=X,USDCHF=X,EURJPY=X,GBPJPY=X,GC=F,SI=F,CL=F,BZ=F,NG=F,HG=F,PL=F,ES=F,NQ=F,BTC-USD,ETH-USD,ZN=F

# Интервал свечей и период истории
YFINANCE_INTERVAL=5m
YFINANCE_PERIOD=1mo

# Как часто сканировать (секунды)
POLL_INTERVAL_SEC=300

# Через сколько минут проверять точность (через запятую)
VERIFY_HORIZONS=15,30,60

LOG_LEVEL=INFO

# FxPro API (опционально, по умолчанию выключено — используется yfinance)
FXPRO_ENABLED=false
FXPRO_CLIENT_ID=
FXPRO_CLIENT_SECRET=
FXPRO_ACCOUNT_ID=
FXPRO_API_URL=https://connect.fxpro.com/api/v1

# Гипотетический счёт для расчёта P&L
ACCOUNT_BALANCE=250.0
LOT_SIZE=0.01
# ATR-scaled risk per trade в USD. 0 = отключить (fallback на LOT_SIZE).
# Default $15 = 1% от $1500 депо (Van K. Tharp 2007 ch.11).
RISK_PER_TRADE_USD=15.0
# Hard cap на ATR-scaled lot. Default 0.05 (safeguard после инцидента
# 23.04.2026 -$128/час, см. BUILDLOG.md). Поднимать только при осознанном
# user-acceptance высокого риска.
MAX_LOT_SIZE=0.05

# Whale-трекер
WHALE_COT_ENABLED=true
WHALE_SENTIMENT_ENABLED=false
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=

# Стратегия Leaders (copy-trading за китами)
LEADERS_ENABLED=true
LEADERS_MAX_POSITIONS=20
LEADERS_CAPITAL_PCT=0.67
LEADERS_SL_ATR=2.0
LEADERS_TRAIL_ATR=0.7

# Стратегия Outsiders (extreme setups)
OUTSIDERS_ENABLED=true
OUTSIDERS_MAX_POSITIONS=50
OUTSIDERS_CAPITAL_PCT=0.33
OUTSIDERS_MODE=confirmed

# Shadow analytics
SHADOW_ENABLED=true

# Скальпинг-стратегии
SCALPING_VWAP_ENABLED=true
SCALPING_STATARB_ENABLED=true
SCALPING_ORB_ENABLED=true
SCALPING_MAX_POSITIONS=50

# cTrader Open API (автоторговля)
CTRADER_TRADING_ENABLED=false
CTRADER_HOST_TYPE=demo
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_REDIRECT_URI=https://openapi.ctrader.com/apps/token

# Kill Switch (защита от потерь)
KILLSWITCH_MAX_DAILY_LOSS=50.0
KILLSWITCH_MAX_DRAWDOWN_PCT=20.0
KILLSWITCH_MAX_POSITIONS=10
KILLSWITCH_MAX_LOSS_PER_TRADE=25.0

# ═══════════════════════════════════════════════════════════════
# BYBIT CRYPTO BOT (отдельный бот, отдельный контейнер)
# ═══════════════════════════════════════════════════════════════
#
# Единственный источник правды для дефолтов — settings.py.
# Здесь задаются только переменные, которые ОТЛИЧАЮТСЯ от дефолтов,
# плюс секреты (API_KEY, API_SECRET).
# Если переменная не задана — Pydantic берёт default из кода.

# Bybit API (создать на bybit.com → API Management → Demo Trading)
BYBIT_BOT_API_KEY=
BYBIT_BOT_API_SECRET=
BYBIT_BOT_DEMO=true
BYBIT_BOT_TRADING_ENABLED=true

# Список символов: по умолчанию берётся из DEFAULT_SYMBOLS в settings.py (42 шт).
# Раскомментируй для override:
# BYBIT_BOT_SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Управление капиталом (defaults: balance=500, leverage=5, pct=0.05)
# Раскомментируй для override:
# BYBIT_BOT_ACCOUNT_BALANCE=500
# BYBIT_BOT_LEVERAGE=5

# Kill Switch (defaults: daily_loss=37.50, drawdown=25%, positions=5)
# Раскомментируй для override:
# BYBIT_BOT_KS_MAX_DAILY_LOSS=37.50
# BYBIT_BOT_KS_MAX_DRAWDOWN_PCT=25.0
# BYBIT_BOT_KS_MAX_POSITIONS=5

BYBIT_BOT_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# AI-TRADER (DeepSeek-V4, отдельный бот, отдельный контейнер)
# ═══════════════════════════════════════════════════════════════
# Двойной таймер (v0.10-backport, 2026-05-12): full-cycle делает полный
# анализ (indicators + news), review-cycle между full только следит за
# уже открытыми позициями (close/hold, без open) — даёт LLM в 3х больше
# точек реакции на adverse evidence до того как сработает биржевой SL.
# 0 = review отключён.
# AI_TRADER_POLL_INTERVAL_SEC=900     # full-cycle (15 мин)
# AI_TRADER_REVIEW_INTERVAL_SEC=300   # review-cycle (5 мин)
#
# v0.30 (2026-05-28, institutional rewrite — port FX-trader patterns):
# - macro_rates: DXY (DX-Y.NYB) + UST10Y (^TNX) через yfinance, no key.
#   Закрывает hidden-disconnect «промпт обещает DXY, контекст не отдаёт»
#   (та же нестыковка что у FX-bot до D1 deploy 2026-05-27).
# AI_TRADER_MACRO_RATES_ENABLED=true
# AI_TRADER_MACRO_RATES_CACHE_TTL_SEC=1800
# - crypto_macro: BTC dominance + total crypto market cap через
#   CoinGecko /global (free, 10k calls/month, no key). Cache 1h = 720
#   calls/month.
# AI_TRADER_CRYPTO_MACRO_ENABLED=true
# AI_TRADER_CRYPTO_MACRO_CACHE_TTL_SEC=3600
# - REGIME-CHANGE WINDOW (Lopez de Prado 2018 ch.7 + Hamilton 1989):
#   SELF-REFLECTION фильтр на opened_at >= этой даты. Pre-v0.30 trades
#   = другая DGP (без THESIS DISCIPLINE), включение в self-reflection
#   = curve-fitting. Пустая строка = legacy behavior (учитываем всю
#   историю). Date обновляется на каждый «structural break» deploy.
# AI_TRADER_STATS_WINDOW_START=2026-05-30T00:00:00+00:00
# - 5-dim news sentiment: aggregate_uncertainty > этого порога →
#   open блокируется в executor. Default 0.7 (паритет FX-trader gate).
#   COLD-START discovery trades используют 0.5 (см. SYSTEM_PROMPT).
# AI_TRADER_NEWS_UNCERTAINTY_BLOCK=0.7
#
# v0.31 (2026-05-28, aggressive mandate по запросу пользователя):
# - killswitch $350/day (было $50) = 70% capital. Позволяет ~35 убыточных
#   сделок при risk-per-trade $10.
# - max_positions 5 (было 3) = больше параллельных setup'ов.
# - max_position_size_usd $100 (новое явное поле; было неявное =
#   virtual_capital $500). С leverage до 5x → notional до $500 = весь
#   капитал. Confidence-to-size mapping в SYSTEM_PROMPT:
#     low 0.30-0.49: $25-50; medium 0.50-0.69: $50-75; high 0.70+: $75-100.
# - max_total_loss $400 (было $200) = halt при потере 80% capital.
# Промпт: "actively seek setups" (заменено "most cycles HOLD"); explicit
# cost awareness блок (fee_RT + funding settlement) в commentary +
# optional `cost_estimate_usd` в open-JSON для audit log.
# Reset n=0: новые лимиты = новый DGP (см. no-data-fitting.mdc).
# AI_TRADER_MAX_DAILY_LOSS=350.0
# AI_TRADER_MAX_TOTAL_LOSS=400.0
# AI_TRADER_MAX_POSITIONS=5
# AI_TRADER_MAX_POSITION_SIZE_USD=100.0

# v0.33 (2026-05-28): Raise deepseek_max_tokens 4096 → 8192 (default).
# С v0.30 + v0.31 + v0.32 verbose commentary (EQUITY READ + MACRO REGIME +
# PER-ASSET HIERARCHY + MFP + COST AWARENESS) thinking-блоки + ответ +
# JSON не умещались в 4096 → "Parse error: no JSON object found".
# 8192 — beta-лимит DeepSeek API (https://api-docs.deepseek.com/news/news0725
# "8K max_tokens (Beta)"), принимается Anthropic-compat без streaming.
# Выше 8192 (16384/32768) ловим:
#   ValueError: Streaming is required for operations that may take longer
#   than 10 minutes (защита Anthropic SDK от 10-min timeout).
# AI_TRADER_DEEPSEEK_MAX_TOKENS=8192

# ═══════════════════════════════════════════════════════════════
# FX AI TRADER (DeepSeek-V4 на cTrader FxPro: gold + Brent oil)
# ═══════════════════════════════════════════════════════════════
# Phase 1: paper-mode минимум 14 дней. Trading_enabled=false по умолчанию.
# Включать LIVE только после: подтверждённой стабильности парсера,
# калибровки sentiment-uncertainty gate, ≥30 paper-trades, ≥2-нед
# сбора данных в разных режимах (тренд/флет/новости) (sample-size.mdc).
#
# AI_FX_TRADER_TRADING_ENABLED=false
# AI_FX_TRADER_SYMBOLS=XAUUSD,BZ=F
# AI_FX_TRADER_ORDER_LABEL=ai-fx-trader   # broker-side изоляция от Advisor (label=fx-pro-bot)
# AI_FX_TRADER_POLL_INTERVAL_SEC=900      # full-cycle 15 мин
# AI_FX_TRADER_REVIEW_INTERVAL_SEC=300    # review-cycle 5 мин
# AI_FX_TRADER_VIRTUAL_CAPITAL=500
#
# KillSwitch v1.0 (12-May-2026, переработан на broker-safety only):
# LLM получил свободу discretionary trader — R:R / risk-per-trade /
# correlation он решает сам по setup'у (Mark Douglas / Van Tharp).
# Здесь только catastrophic-loss caps + broker margin safety.
# AI_FX_TRADER_MAX_DAILY_LOSS=150         # catastrophic, не tuning
# AI_FX_TRADER_MAX_TOTAL_LOSS=300         # halt эксперимент
# AI_FX_TRADER_MAX_POSITIONS=3            # broker margin safety / runaway-protection
# AI_FX_TRADER_MAX_POSITIONS_PER_SYMBOL=3 # = общий лимит (sanity)
# AI_FX_TRADER_MAX_LOT_SIZE=0.50          # broker margin floor (важно)
# Удалены в v1.0 (env vars игнорируются если выставлены):
# - AI_FX_TRADER_RISK_PER_TRADE_USD (LLM сам решает по Van Tharp R-multiple)
# - AI_FX_TRADER_CORRELATION_HAIRCUT (LLM сам решает аллокацию gold+oil)
#
# OAuth-токены изолированы от Advisor (отдельный файл и отдельный grant).
# Перед первым стартом — пройти fx-pro-auth и положить токены в этот
# файл. См. BUILDLOG_AI_FX_TRADER.md «token rotation hardening».
# AI_FX_TRADER_CTRADER_TOKEN_PATH=/data/ctrader_tokens_ai_fx.json
#
# LLM (DeepSeek через Anthropic-compat). Дефолтный max_tokens=8000:
# full-cycle output = thinking + commentary + JSON с multi-dim sentiment
# (~300–600 токенов). На 4096 наблюдался обрезанный JSON (12.05.2026).
# AI_FX_TRADER_DEEPSEEK_MAX_TOKENS=8000
# AI_FX_TRADER_DEEPSEEK_THINKING=true
# output_config.effort для DeepSeek-V4 Anthropic-compat endpoint:
# low | medium | high (default, рекомендовано) | max. Пустая строка
# отключает передачу (использовать default endpoint'а). См. BUILDLOG
# 2026-05-26 v4-prompt-tune для обоснования.
# AI_FX_TRADER_DEEPSEEK_EFFORT=high
#
# EIA Open Data (бесплатная регистрация на eia.gov — без ключа RSS-only).
# AI_FX_TRADER_EIA_API_KEY=
# AI_FX_TRADER_EIA_CACHE_TTL_SEC=21600     # 6 часов
#
# Macro rates feed (2026-05-27 D1): DXY (DX-Y.NYB) / UST10Y (^TNX) /
# TIPS ETF (TIP) через yfinance, без API-ключа. SYSTEM_PROMPT ссылается
# на эти ряды как primary gold-драйверы. Default = on; в тестах /
# при сбое yfinance — false. Cache 30 мин.
# AI_FX_TRADER_MACRO_RATES_ENABLED=true
# AI_FX_TRADER_MACRO_RATES_CACHE_TTL_SEC=1800

# Live spot-price stream (Phase 1, 2026-05-29). Подписка на
# ProtoOASubscribeSpots → реальная цена вместо H1-close. Default=on.
# max_age_sec — backstop на молчащее соединение (фолбэк на M1-close).
# AI_FX_TRADER_LIVE_PRICE_ENABLED=true
# AI_FX_TRADER_LIVE_PRICE_MAX_AGE_SEC=300

# ═══════════════════════════════════════════════════════════════
# AI ARENA (Nof1 Alpha Arena clone — DeepSeek V4-Pro + Bybit demo)
# ═══════════════════════════════════════════════════════════════
# Отдельный бот, отдельный модуль (src/ai_arena/), отдельная БД,
# отдельный Bybit аккаунт, отдельный Telegram токен.
# Архитектура зафиксирована правилом .cursor/rules/ai-arena-sources.mdc:
# любые правки только из nof1.ai/blog/TechPost1 + gist nof1-prompt.md.

# Bybit API — ОТДЕЛЬНЫЕ ключи от ai_trader / bybit_bot. Получить на
# bybit.com → API Management → создать новый ключ под отдельный
# subaccount (рекомендуется) или Demo Trading. Без ключей бот не
# стартует — выходит чисто.
AI_ARENA_BYBIT_API_KEY=
AI_ARENA_BYBIT_API_SECRET=
AI_ARENA_BYBIT_DEMO=true
# AI_ARENA_BYBIT_CATEGORY=linear  # USDT-perp, не менять без причины

# Trading mode: PAPER по умолчанию (decisions only). LIVE — только
# после dry-run проверки латентности и валидности промпта (см.
# AI_TRADER_PROPOSAL_ALPHA_ARENA.md §9 D12).
AI_ARENA_TRADING_ENABLED=false

# DeepSeek V4-Pro (преемник V3.1, который реально использует Nof1).
# reasoning_effort=off → direct аналог V3.1 standard (Nof1 НЕ
# использует reasoning-mode, см. gist комментарий автора).
# ОТДЕЛЬНЫЙ ключ от ai_trader: даёт независимый rate-limit pool
# (DeepSeek лимиты — на account level) и независимый billing/audit.
# Без ключа бот стартует, логирует ошибку «DEEPSEEK_API_KEY is empty»
# и выходит чисто.
AI_ARENA_DEEPSEEK_API_KEY=
# AI_ARENA_DEEPSEEK_MODEL=deepseek-v4-pro
# AI_ARENA_DEEPSEEK_REASONING=off          # off | high | max
# AI_ARENA_DEEPSEEK_MAX_TOKENS=8192
# AI_ARENA_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# Cycle и капитал (Nof1: cycle 2-3 мин, у нас 600s — v2.z2 deviation,
# см. ai-arena-sources.mdc § «Допустимые исключения» исключение #3).
# AI_ARENA_POLL_INTERVAL_SEC=600           # 10 мин (default v2.z2)
# AI_ARENA_VIRTUAL_CAPITAL=1000            # номинальная метка для SYSTEM_PROMPT
# AI_ARENA_EQUITY_SCALE_DIVISOR=50         # Bybit demo $50k / 50 → LLM видит $1000
#                                          # (адаптация vs Hyperliquid у Nof1).
# AI_ARENA_LEVERAGE_MAX=20                 # source Nof1: 1-20x. Только для подстановки
#                                          # в SYSTEM_PROMPT, серверного hard-check'а нет.
# AI_ARENA_MAX_ALLOCATION_PCT=0.30         # v2.z3: server-side cap на notional одной
#                                          # позиции (qty × price ≤ pct × virtual_capital).
#                                          # 0.30 = $3000 при $10k virtual cap. Откат: 1.0.
#                                          # См. ai-arena-sources.mdc исключение #4.
# AI_ARENA_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
# (1-в-1 Nof1 Asset Universe: BTC, ETH, SOL, BNB, DOGE, XRP. ai_arena
#  работает на отдельном demo-аккаунте, конфликта с bybit_bot нет.)

# КАПИТАЛЬНЫХ HARD-LIMITS НЕТ. Source Nof1 (gist + nof1.ai/blog/TechPost1)
# не содержит server-side killswitch / max_daily_loss / max_total_loss /
# max_positions / max_risk / min_RR cap'ов. Risk management полностью на
# стороне LLM через required JSON-поля (confidence, invalidation_condition,
# risk_usd, stop_loss, profit_target) и Sharpe Ratio feedback.
# Если хочешь добавить hard-cap — это нарушение правила
# .cursor/rules/ai-arena-sources.mdc, требует обсуждения.

# Telegram — ОТДЕЛЬНЫЙ от ai_trader (UX-изоляция). Если токен пустой —
# TG молчит, остальное работает.
# AI_ARENA_TELEGRAM_BOT_TOKEN=
# AI_ARENA_TELEGRAM_CHAT_ID=
# AI_ARENA_TELEGRAM_ENABLED=true

# AI_ARENA_LOG_LEVEL=INFO
